datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ServiceInterest {
  GENERAL
  NBFC_FINANCE
  INSURANCE
  PROPERTY_INVESTMENT
  MUTUAL_FUND
  PARTNERSHIP
}

enum ContactMethod {
  PHONE
  WHATSAPP
  EMAIL
}

enum LeadStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  CONVERTED
  CLOSED
}

model Lead {
  id                     String          @id @default(uuid())
  fullName               String
  phone                  String
  email                  String
  city                   String
  serviceInterest        ServiceInterest @default(GENERAL)
  preferredContactMethod ContactMethod   @default(PHONE)
  message                String
  consent                Boolean
  status                 LeadStatus      @default(NEW)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  @@map("leads")
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  phone     String
  email     String
  message   String
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model BlogPost {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  excerpt   String
  content   String
  category  String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blog_posts")
}
